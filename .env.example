# Primary PostgreSQL connection string for Drizzle, Better Auth, and the production runtime.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metro_trailer?schema=public"

# Optional separate PostgreSQL connection string for append-only audit writes. Falls back to DATABASE_URL when unset.
AUDIT_DATABASE_URL=""

# Runtime mode: use "demo" for the seeded in-memory runtime or "production" for the database-backed services.
METRO_TRAILER_RUNTIME_MODE="demo"

# Public application origin used for portal links, callback URLs, and generated document links.
APP_URL="http://localhost:3000"

# Better Auth base URL. Keep this pointed at the auth API base when running the built-in auth routes.
BETTER_AUTH_URL="http://localhost:3000/api/auth"

# Primary authentication secret for Better Auth sessions, cookies, and fallback credential encryption.
AUTH_SECRET="replace-me-with-a-long-random-secret"

# Dedicated secret for bespoke e-sign signer tokens and signature evidence hashing. Falls back to AUTH_SECRET when unset.
ESIGN_SECRET="replace-me-with-another-long-random-secret"

# Stripe secret key used for server-side payment, customer, and refund operations.
STRIPE_SECRET_KEY=""

# Stripe webhook signing secret used to verify inbound Stripe webhook events in production.
STRIPE_WEBHOOK_SECRET=""

# QuickBooks OAuth client ID used to initiate and refresh QuickBooks Online connections.
QUICKBOOKS_CLIENT_ID=""

# QuickBooks OAuth client secret paired with QUICKBOOKS_CLIENT_ID.
QUICKBOOKS_CLIENT_SECRET=""

# QuickBooks OAuth redirect URI registered in the Intuit app settings.
QUICKBOOKS_REDIRECT_URI=""

# QuickBooks environment: use "sandbox" for test tenants or "production" for live sync.
QUICKBOOKS_ENVIRONMENT="sandbox"

# QuickBooks webhook verifier token used to validate Intuit webhook signatures.
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=""

# Legacy alias for QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN. Leave blank unless you intentionally use the alias.
QUICKBOOKS_WEBHOOK_VERIFIER=""

# Secret used to encrypt persisted QuickBooks access and refresh tokens at rest.
QUICKBOOKS_TOKEN_ENCRYPTION_SECRET=""

# QuickBooks minor API version used when issuing API requests.
QUICKBOOKS_MINOR_VERSION="75"

# Record360 API base URL for unit sync and inspection request calls.
RECORD360_API_BASE_URL=""

# Record360 API key for live unit sync and inspection requests.
RECORD360_API_KEY=""

# Record360 relative path used when creating inspection requests. Defaults to /inspections in code.
RECORD360_INSPECTION_REQUEST_PATH="/inspections"

# Record360 relative path used when syncing unit records. Defaults to /units in code.
RECORD360_UNIT_SYNC_PATH="/units"

# Record360 webhook secret used to verify inbound inspection webhooks.
RECORD360_WEBHOOK_SECRET=""

# Minutes after which a SkyBitz ping is considered stale for recovery and collections workflows.
SKYBITZ_STALE_MINUTES="240"

# Shared AWS region fallback used by S3, SES, and CloudWatch integrations when a service-specific region is not provided.
AWS_REGION=""

# S3 bucket name used for retained documents, invoice PDFs, and bespoke e-sign artifacts.
S3_BUCKET=""

# AWS region for the S3 bucket. Falls back to AWS_REGION when unset.
S3_REGION=""

# Object key prefix applied to all Metro Trailer uploads in the configured bucket.
S3_PREFIX="metro-trailer"

# Optional custom S3-compatible endpoint for non-AWS object storage or local testing.
S3_ENDPOINT=""

# Set to "true" when your S3-compatible endpoint requires path-style URLs instead of virtual-hosted-style URLs.
S3_FORCE_PATH_STYLE="false"

# Optional explicit S3 access key. Leave blank when using IAM roles or ambient AWS credentials.
S3_ACCESS_KEY_ID=""

# Optional explicit S3 secret key. Leave blank when using IAM roles or ambient AWS credentials.
S3_SECRET_ACCESS_KEY=""

# Server-side encryption mode applied to S3 uploads, typically "aws:kms" or "AES256".
S3_SERVER_SIDE_ENCRYPTION="aws:kms"

# AWS KMS key ID or ARN used when S3 uploads are encrypted with aws:kms.
S3_KMS_KEY_ID=""

# Optional S3 Object Lock retention mode applied to retained documents when Object Lock is enabled on the bucket.
S3_OBJECT_LOCK_MODE="COMPLIANCE"

# Number of days to retain Object Lock-protected documents before expiration.
S3_OBJECT_LOCK_DAYS="3650"

# AWS SES region for outbound transactional email. Falls back to AWS_REGION when unset.
SES_REGION=""

# Verified SES sender address used for auth, billing, signature, and operational notification emails.
SES_FROM_EMAIL=""

# Comma-delimited workflow identifiers that should be globally disabled in production.
METRO_TRAILER_DISABLED_WORKFLOWS=""

# JSON object mapping branch IDs or branch numbers to arrays of disabled workflow identifiers.
METRO_TRAILER_BRANCH_DISABLED_WORKFLOWS="{}"

# CloudWatch namespace used when emitting operational metrics from the observability layer.
METRO_TRAILER_CLOUDWATCH_NAMESPACE=""

# Sentry DSN used for application and worker exception reporting.
SENTRY_DSN=""

# Logical environment name reported to Sentry.
SENTRY_ENVIRONMENT="development"
