{
  "name": "metro-trailer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "local:dev": "next dev -p 3001",
    "build": "node scripts/build.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/lib/dashboard-preferences.test.ts src/lib/search-core.test.ts src/lib/server/pricing-engine.test.ts src/lib/server/work-orders.lifecycle.test.ts src/lib/server/esign-fields.test.ts src/lib/server/runtime-surface.test.ts src/lib/server/inventory.lifecycle.integration.test.ts src/lib/server/commercial.lifecycle.integration.test.ts src/lib/legacy/tooling.test.ts src/lib/testing/perf-harness.test.ts src/lib/testing/security-audit.test.ts",
    "local:db:serve": "tsx scripts/local-db-serve.ts",
    "local:db:start": "tsx scripts/local-db-start.ts",
    "local:db:stop": "tsx scripts/local-db-stop.ts",
    "local:bootstrap:admin": "tsx scripts/bootstrap-local-admin.ts",
    "local:setup": "tsx scripts/local-setup.ts",
    "legacy:import": "tsx scripts/legacy-import.ts",
    "legacy:reconcile": "tsx scripts/legacy-reconcile.ts",
    "fixed-assets:import": "python scripts/fixed-assets-import.py",
    "customers:legacy-import": "python scripts/customer-legacy-import.py",
    "bc:export": "tsx business-central/scripts/bc-export.ts",
    "bc:permission-checklist": "tsx business-central/scripts/bc-generate-permission-checklist.ts",
    "bc:seed:db": "tsx business-central/scripts/bc-seed-db.ts",
    "record360:test-fetch": "tsx record360/scripts/test-record360-fetch.ts",
    "record360:sync:bc": "tsx record360/scripts/record360-sync-bc.ts",
    "sharepoint:sync:bc": "tsx sharepoint/scripts/sharepoint-sync-bc.ts",
    "sync:worker": "tsx aws/worker/sync-worker.ts",
    "aws:cdk": "cdk --app \"npx tsx aws/bin/metro-sync-backend.ts\"",
    "aws:synth": "cdk synth --app \"npx tsx aws/bin/metro-sync-backend.ts\"",
    "aws:deploy": "cdk deploy --app \"npx tsx aws/bin/metro-sync-backend.ts\"",
    "skybitz:test-auth": "tsx skybitz/scripts/test-auth.ts",
    "skybitz:latest-locations": "tsx skybitz/scripts/fetch-latest-locations.ts",
    "skybitz:sync:bc": "tsx skybitz/scripts/skybitz-sync-bc.ts",
    "skybitz:sync:bc:latest": "tsx skybitz/scripts/skybitz-sync-bc.ts --latest-snapshot",
    "skybitz:sync:bc:history": "tsx skybitz/scripts/skybitz-sync-bc.ts --history-window",
    "perf:harness": "tsx scripts/perf-harness.ts",
    "security:audit": "tsx scripts/security-audit.ts",
    "e2e:smoke": "tsx scripts/e2e-smoke.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:validate": "drizzle-kit check --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/client-ses": "^3.1029.0",
    "@aws-sdk/client-sqs": "^3.1029.0",
    "better-auth": "^1.6.2",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.11.0",
    "stripe": "^22.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1041.0",
    "@aws-sdk/client-codebuild": "^3.1041.0",
    "@aws-sdk/client-dynamodb": "^3.1041.0",
    "@aws-sdk/client-ecs": "^3.1041.0",
    "@aws-sdk/client-secrets-manager": "^3.1041.0",
    "@aws-sdk/client-sts": "^3.1041.0",
    "@aws-sdk/lib-dynamodb": "^3.1041.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "aws-cdk": "^2.1120.0",
    "aws-cdk-lib": "^2.252.0",
    "constructs": "^10.6.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.10",
    "embedded-postgres": "^18.3.0-beta.16",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
