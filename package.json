{
  "name": "metro-trailer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "local:dev": "next dev -p 3001",
    "build": "node scripts/build.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/lib/server/pricing-engine.test.ts src/lib/server/work-orders.lifecycle.test.ts src/lib/server/esign-fields.test.ts src/lib/server/runtime-surface.test.ts src/lib/legacy/tooling.test.ts src/lib/testing/perf-harness.test.ts src/lib/testing/security-audit.test.ts",
    "local:db:serve": "tsx scripts/local-db-serve.ts",
    "local:db:start": "tsx scripts/local-db-start.ts",
    "local:db:stop": "tsx scripts/local-db-stop.ts",
    "local:bootstrap:admin": "tsx scripts/bootstrap-local-admin.ts",
    "local:setup": "tsx scripts/local-setup.ts",
    "legacy:import": "tsx scripts/legacy-import.ts",
    "legacy:reconcile": "tsx scripts/legacy-reconcile.ts",
    "perf:harness": "tsx scripts/perf-harness.ts",
    "security:audit": "tsx scripts/security-audit.ts",
    "e2e:smoke": "tsx scripts/e2e-smoke.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:validate": "drizzle-kit check --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/client-ses": "^3.1029.0",
    "@aws-sdk/client-sqs": "^3.1029.0",
    "better-auth": "^1.6.2",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.11.0",
    "stripe": "^22.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.10",
    "embedded-postgres": "^18.3.0-beta.16",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
